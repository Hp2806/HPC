#include <stdio.h>
#include <stdlib.h>
#include <omp.h>
int main() {
    int n, target, count = 0;
    printf("Enter the number of elements: ");
    scanf("%d", &n);
    int *arr = (int *)malloc(n * sizeof(int));
    printf("Enter %d elements:\n", n);
    for (int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }
    printf("Enter the target value: ");
    scanf("%d", &target);
    #pragma omp parallel for reduction(+:count)
    for (int i = 0; i < n; i++) {
        if (arr[i] < target) {
            count++;
        }
    }
    printf("\nNumber of values less than %d is: %d\n", target, count);

    free(arr);
    return 0;
}
