#include <stdio.h>
#include <string.h>
#include <ctype.h>
#include <mpi.h>
#define MAX 100
#define TYPE1 1
#define TYPE2 2
int isPalindrome(char str[])
{
    int i = 0, j = strlen(str) - 1;
    while (i < j)
    {
        if (str[i] != str[j])
            return 0;
        i++;
        j--;
    }
    return 1;
}
int main(void)
{
    int my_rank, comm_sz;
    char msg[MAX];
    MPI_Init(NULL, NULL);
    MPI_Comm_rank(MPI_COMM_WORLD, &my_rank);
    MPI_Comm_size(MPI_COMM_WORLD, &comm_sz);
    if (my_rank == 1)
    {
        sprintf(msg,"Hello");
        MPI_Send(msg, strlen(msg) + 1, MPI_CHAR,0, TYPE1, MPI_COMM_WORLD);
    }
    else if(my_rank == 2) 
    {
        sprintf(msg,"Hi");
        MPI_Send(msg, strlen(msg) + 1, MPI_CHAR,0,TYPE2, MPI_COMM_WORLD);
    }
    else if(my_rank == 3)
    {
        sprintf(msg,"Level");
        MPI_Send(msg, strlen(msg) + 1, MPI_CHAR,0, TYPE1, MPI_COMM_WORLD);
    }
    else if(my_rank == 4)
    {
        sprintf(msg,"World");
        MPI_Send(msg, strlen(msg) + 1, MPI_CHAR,0, TYPE2, MPI_COMM_WORLD);
    }
    else
    {
        MPI_Status status;

        for (int i = 1; i < comm_sz; i++)
        {
            MPI_Recv(msg, MAX, MPI_CHAR,
                     i, MPI_ANY_TAG, MPI_COMM_WORLD, &status);
            if (status.MPI_TAG == TYPE1)
            {
                for (int k = 0; msg[k]; k++)
                    msg[k] = toupper(msg[k]);
                printf("From rank %d (Type 1): Uppercase = %s\n",
                       i, msg);
            }
            else if (status.MPI_TAG == TYPE2)
            {
                if (isPalindrome(msg))
                    printf("From rank %d (Type 2): %s is a Palindrome\n",
                           i, msg);
                else
                    printf("From rank %d (Type 2): %s is NOT a Palindrome\n",
                           i, msg);
            }
        }
    }
    MPI_Finalize();
    return 0;
}
