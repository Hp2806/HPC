#include <stdio.h>
#include <stdlib.h>
#include <omp.h>
int main() {
    int n = 1000000;
    int *A, *B, *C;
    A = (int*) malloc(n * sizeof(int));
    B = (int*) malloc(n * sizeof(int));
    C = (int*) malloc(n * sizeof(int));
    for(int i = 0; i < n; i++) {
        A[i] = i;
        B[i] = i * 2;
    }
    #pragma omp parallel for
    for(int i = 0; i < n; i++) {
        C[i] = A[i] + B[i];
    }
    printf("Sample Output:\n");
    for(int i = 0; i < 5; i++) {
        printf("%d + %d = %d\n", A[i], B[i], C[i]);
    }
    free(A);
    free(B);
    free(C);

    return 0;
}
