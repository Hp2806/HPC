#include<stdio.h>
#include<unistd.h>
#include<time.h> 
#define MAX 50
int main()
{
   int m,n,p;
   int A[MAX][MAX], B[MAX][MAX], c[MAX][MAX];
   long iterations = 100000; 
   printf("Enter m , n , p: ");
   scanf("%d %d %d",&m,&n,&p);
   printf("Enter matrix A(%d * %d):\n",m,n);
   int i,j,k;
   for(i = 0; i < m; i++){
      for(j = 0; j < n; j++){
         scanf("%d",&A[i][j]);
      }
   }
   printf("Enter matrix B(%d * %d):\n",n,p);
   for(i = 0; i < n; i++){
      for(j = 0; j < p; j++){
         scanf("%d",&B[i][j]);
      }
   }
   clock_t start = clock();
   int count;
   for(count = 0; count < iterations; count++)
   {
       for(i = 0; i < m; i++)
       {
          for(j = 0; j < p; j++)
          {
             c[i][j] = 0; 
             for(k = 0; k < n; k++)
             {
                c[i][j] += A[i][k] * B[k][j];
             }
          }
       }
   }
   clock_t end = clock();
   printf("Result of serial matrix:\n");
   for(i = 0; i < m; i++)
   {
      for(j = 0; j < p; j++)
      {
         printf("%d\t",c[i][j]);
      }
      printf("\n");
   }
   double total_seconds = (double)(end - start) / CLOCKS_PER_SEC;
   double single_run_seconds = total_seconds / iterations;
   double milliseconds = single_run_seconds * 1000.0;
   printf("Serial time: %.7f milliseconds\n",milliseconds);   
   return 0;
}
