#define _POSIX_C_SOURCE 199309L
#include <stdio.h>
#include <stdlib.h> 
#include <time.h>   
#define MAX 1001
int A[MAX][MAX], B[MAX][MAX], C[MAX][MAX];
int main() {
    int m, n, p;
    int i, j, k;
    printf("Enter m, n, p: ");
    if(scanf("%d %d %d", &m, &n, &p) != 3) {
       printf("Invalid input\n");
       return 1;
    }
    if (m > MAX || n > MAX || p > MAX) {
        printf("Dimensions exceed MAX value %d\n", MAX);
        return 1;
    }
    srand(time(NULL)); 
    for (i = 0; i < m; i++) {
        for (j = 0; j < n; j++) {
            A[i][j] = rand() % 10; 
        }
    }
    for (i = 0; i < n; i++) {
        for (j = 0; j < p; j++) {
            B[i][j] = rand() % 10; 
        }
    }
    struct timespec start, end;
    clock_gettime(CLOCK_MONOTONIC, &start);
    for (i = 0; i < m; i++) {
        for (j = 0; j < p; j++) {
            C[i][j] = 0; 
            for (k = 0; k < n; k++) {
                C[i][j] += A[i][k] * B[k][j];
            }
        }
    }
    clock_gettime(CLOCK_MONOTONIC, &end);
    long long diff_nanos = (end.tv_sec - start.tv_sec) * 1000000000LL + (end.tv_nsec - start.tv_nsec);
    printf("\nExecution Time of serial matrix multiplication: %lld nanoseconds\n", diff_nanos);
    return 0;
}
